{% if (!blank_page): %}
				<!-- Footer -->
				<footer class="cbi-section main-footer" style="display: flex; justify-content: flex-end; align-items: center; padding: 0.5rem 1.25rem !important; margin-top: 1rem; margin-bottom: 1rem;">
					<div class="login-footer" style="margin-top: 0; text-align: right; margin-left: auto; display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted);">
